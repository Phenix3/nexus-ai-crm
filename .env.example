# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Database ─────────────────────────────────────────────────────────────────
# Supabase dashboard → Settings → Database → Connection string

# 1) Transaction pooler (port 6543) — used by the Next.js app at runtime
#    Mode: Transaction | Settings > Database > Connection pooling
DATABASE_URL=postgresql://postgres.your-project:your-password@aws-0-eu-west-3.pooler.supabase.com:6543/postgres

# 2) Session pooler (port 5432) — used by drizzle-kit for migrations (DDL requires a persistent connection)
#    Mode: Session | same page, switch the mode dropdown to "Session"
DIRECT_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.lieoikdtbpyjlukoekuz.supabase.co:5432/postgres

# App URL (used for invite links etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — https://resend.com/
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@nexuscrm.io

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth — Gmail integration
# 1. Create a project at https://console.cloud.google.com/
# 2. Enable Gmail API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add redirect URI: http://localhost:3000/api/auth/gmail/callback (+ prod URL)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Token encryption — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Vercel Cron secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# Upstash Redis — rate limiting on auth routes + AI response caching
# Get from https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# E2E test secret (only used in dev/test — gates /api/test/* endpoints)
E2E_SECRET=change-me

# Sentry — https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN=https://...@o123456.ingest.sentry.io/...
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=nexus-crm
SENTRY_AUTH_TOKEN=sntrys_...

# PostHog — https://eu.posthog.com/
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
